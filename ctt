#!/bin/bash

set -e

WORKSPACE_DIR="$HOME/work"
WORKTREE_DIR="$WORKSPACE_DIR/worktrees"
CONFIG_DIR="${HOME}/.config/ctt"

if ! command -v fzf &> /dev/null; then
    echo "Error: fzf is not installed." >&2
    exit 1
fi

select_repo() {
    local repo
    repo=$(find . -maxdepth 5 -type d -name ".git" -prune -exec dirname {} \; | fzf --prompt="Select Repository> ")

    if [ -z "$repo" ]; then
        echo "Cancelled." >&2
        exit 1
    fi

    echo "$repo"
}

select_branch() {
    local out query selected

    out=$({
        git branch --format="%(refname:short)"
        git branch -r --format="%(refname:short)" | sed 's|^[^/]*/||'
    } | grep -v '^HEAD$' | sort -u | fzf --print-query --prompt="Select or Type Branch for Worktree> ")

    query=$(echo "$out" | head -n 1)
    selected=$(echo "$out" | tail -n +2 | head -n 1)

    if [ -n "$selected" ]; then
        echo "$selected"
        echo "existing"
    elif [ -n "$query" ]; then
        echo "$query"
        echo "new"
    else
        echo "Cancelled." >&2
        exit 1
    fi
}

ask_branch_action() {
    local action
    action=$(printf "Checkout this branch\nCreate new branch from this branch" | fzf --prompt="Select action> ")

    case "$action" in
        "Checkout this branch")
            echo "checkout"
            ;;
        "Create new branch from this branch")
            echo "new_from_base"
            ;;
        *)
            echo "Cancelled." >&2
            exit 1
            ;;
    esac
}

input_new_branch_name() {
    local name
    read -rp "New branch name> " name
    if [ -z "$name" ]; then
        echo "Cancelled." >&2
        exit 1
    fi
    echo "$name"
}

create_worktree() {
    local workdir="$1"
    shift

    if [ -d "${workdir}" ]; then
        read -rp "Directory already exists: ${workdir} — Use existing worktree? [y/N] " yn
        if [[ "$yn" =~ ^[Yy]$ ]]; then
            echo "existing:${workdir}"
            return
        else
            echo "Cancelled." >&2
            exit 1
        fi
    fi

    git worktree add "${workdir}" "$@" >&2
    echo "new:${workdir}"
}

link_ignored_files() {
    local repo_dir="$1"
    local workdir="$2"
    local ignore_file="${CONFIG_DIR}/.worktree-link-ignore"
    local skip_patterns=()

    # Load skip patterns from .worktree-link-ignore if it exists
    if [ -f "$ignore_file" ]; then
        while IFS= read -r line; do
            [[ "$line" =~ ^[[:space:]]*# ]] && continue
            [[ -z "${line// }" ]] && continue
            skip_patterns+=("$line")
        done < "$ignore_file"
    fi

    local linked=0
    while IFS= read -r path; do
        [ -z "$path" ] && continue
        path="${path%/}"

        local src="${repo_dir}/${path}"
        local dst="${workdir}/${path}"

        [ -e "$src" ] || continue

        # Skip if matching a .worktree-link-ignore pattern
        local skip=false
        for pattern in "${skip_patterns[@]}"; do
            if [[ "$path" == $pattern ]]; then
                skip=true
                break
            fi
        done
        $skip && continue

        # Skip if already exists
        if [ -e "$dst" ] || [ -L "$dst" ]; then
            continue
        fi

        echo "Linking... :${src}" >&2

        mkdir -p "$(dirname "$dst")"
        if [ -d "$src" ]; then
            mkdir -p "$dst"
            for item in "$src"/*; do
                [ -e "$item" ] || continue
                local item_name
                item_name=$(basename "$item")
                [ -e "$dst/$item_name" ] || [ -L "$dst/$item_name" ] && continue
                ln -s "$item" "$dst/$item_name"
            done
        else
            ln -s "$src" "$dst"
        fi
        linked=$((linked + 1))
        echo "Linked: ${path}" >&2
    done < <(cd "$repo_dir" && git ls-files --others --ignored --exclude-standard --directory 2>/dev/null)

    if [ "$linked" -gt 0 ]; then
        echo "Linked ${linked} ignored file(s) into worktree." >&2
    fi
}

open_editor() {
    local repo_name="$1"
    local workdir="$2"
    local branch="$3"
    local resume="${4:-false}"
    local tmux_window_name="${repo_name}__${branch}"
    local terminal_title="Claude: ${repo_name} [${branch}]"
    local claude_cmd="ClaudeCode"
    if [ "$resume" = "true" ]; then
        claude_cmd="ClaudeCode --continue"
    fi

    if [ -n "$TMUX" ]; then
        echo "Opening in new tmux window..."
        tmux new-window -n "$tmux_window_name" -c "$workdir" \
            "printf '\\033]0;%s\\007' \"$terminal_title\"; nvim . -c \"$claude_cmd\""
    else
        echo "Warning: not in tmux session. Opening in current terminal..."
        cd "$workdir" || exit 1
        printf '\033]0;%s\007' "$terminal_title"
        nvim . -c "$claude_cmd"
    fi
}

get_task_status() {
    local workdir="$1"
    local branch
    branch=$(git -C "$workdir" rev-parse --abbrev-ref HEAD 2>/dev/null)

    # Count uncommitted changes
    local uncommitted
    uncommitted=$(git -C "$workdir" status --porcelain 2>/dev/null | wc -l | tr -d ' ')

    # Commits ahead of main
    local commits_ahead
    commits_ahead=$(git -C "$workdir" log --oneline origin/main..HEAD 2>/dev/null | wc -l | tr -d ' ')

    # PR status (gh CLI)
    local pr_state=""
    local pr_url=""
    local remote_url
    remote_url=$(git -C "$workdir" remote get-url origin 2>/dev/null)
    if [ -n "$remote_url" ]; then
        local repo_slug
        repo_slug=$(echo "$remote_url" | sed -E 's|.*github\.com[:/]||;s|\.git$||')
        local pr_json
        pr_json=$(gh pr list --repo "$repo_slug" --head "$branch" --state all --json state,url --limit 1 2>/dev/null)
        if [ -n "$pr_json" ] && [ "$pr_json" != "[]" ]; then
            pr_state=$(echo "$pr_json" | head -1 | sed -E 's/.*"state":"([^"]+)".*/\1/')
            pr_url=$(echo "$pr_json" | head -1 | sed -E 's/.*"url":"([^"]+)".*/\1/')
        fi
    fi

    # Determine status
    local status
    if [ "$pr_state" = "MERGED" ]; then
        status="merged"
    elif [ "$pr_state" = "OPEN" ]; then
        status="pr-open"
    elif [ "$uncommitted" -gt 0 ] || [ "$commits_ahead" -gt 0 ]; then
        status="in-progress"
    else
        status="no-changes"
    fi

    echo -e "${status}\t${branch}\t${uncommitted} changed\t${commits_ahead} commits\t${pr_url}"
}

usage() {
    echo "Usage: ctt <command>" >&2
    echo "" >&2
    echo "Commands:" >&2
    echo "  new    Create a worktree and launch ClaudeCode" >&2
    echo "  ls     List active tasks" >&2
    echo "  open   Open a task in the editor" >&2
    echo "  status Show task status (--all for all tasks)" >&2
    echo "  done   Complete a task and remove its worktree" >&2
    exit 1
}

cmd_ls() {
    local dir
    dir="$WORKTREE_DIR"

    if [ ! -d "$dir" ]; then
        echo "Worktree directory not found: $dir" >&2
        exit 1
    fi

    local found=false
    for entry in "$dir"/*/; do
        [ -d "$entry" ] || continue
        found=true
        basename "$entry"
    done

    if [ "$found" = false ]; then
        echo "No active tasks." >&2
    fi
}

cmd_status() {
    local dir
    dir="$WORKTREE_DIR"

    if [ "$1" = "--all" ]; then
        cmd_ls | while read -r task; do
            local workdir="${dir}/${task}"
            local info
            info=$(get_task_status "$workdir")
            echo -e "${task}\t${info}"
        done
        return
    fi

    local selected
    selected=$(cmd_ls | fzf --prompt="Select Task> ")
    if [ -z "$selected" ]; then
        echo "Cancelled." >&2
        exit 1
    fi

    local workdir="${dir}/${selected}"
    echo "Task: ${selected}" >&2
    echo "---" >&2
    get_task_status "$workdir"
}

cmd_done() {
    local dir
    dir="$WORKTREE_DIR"

    local selected
    selected=$(cmd_ls | fzf --prompt="Select Task to Complete> ")
    if [ -z "$selected" ]; then
        echo "Cancelled." >&2
        exit 1
    fi

    local workdir="${dir}/${selected}"

    # Show status
    echo "Task: ${selected}" >&2
    local status_line
    status_line=$(get_task_status "$workdir")
    echo "$status_line" >&2
    echo "---" >&2

    local status
    status=$(echo "$status_line" | cut -f1)

    # Confirm based on status
    case "$status" in
        merged|no-changes)
            read -rp "Remove this worktree? [y/N] " yn
            ;;
        in-progress)
            echo "Warning: uncommitted or unmerged changes exist." >&2
            read -rp "Are you sure you want to remove it? [y/N] " yn
            ;;
        pr-open)
            echo "Warning: PR is still open." >&2
            read -rp "Are you sure you want to remove it? [y/N] " yn
            ;;
    esac

    if [[ ! "$yn" =~ ^[Yy]$ ]]; then
        echo "Cancelled." >&2
        exit 1
    fi

    # Kill tmux window if it exists
    if [ -n "$TMUX" ] && tmux list-windows -F '#{window_name}' | grep -qx "$selected"; then
        read -rp "tmux window '${selected}' is open. Close it? [y/N] " close_win
        if [[ "$close_win" =~ ^[Yy]$ ]]; then
            tmux kill-window -t "$selected"
            echo "Closed tmux window: ${selected}" >&2
        fi
    fi

    # Remove worktree (run from parent repo)
    local git_dir
    git_dir=$(git -C "$workdir" rev-parse --git-common-dir 2>/dev/null)
    if [ -z "$git_dir" ]; then
        echo "Error: failed to get git repository info: ${workdir}" >&2
        exit 1
    fi
    git --git-dir="$git_dir" worktree remove "$workdir" --force

    # Delete local branch if it exists
    local branch="${selected#*__}"
    if git --git-dir="$git_dir" branch --list "$branch" | grep -q .; then
        read -rp "Delete local branch '${branch}'? [y/N] " del_branch
        if [[ "$del_branch" =~ ^[Yy]$ ]]; then
            if ! git --git-dir="$git_dir" branch -d "$branch" 2>/dev/null 1>&2; then
                echo "Warning: branch '${branch}' is not fully merged." >&2
                read -rp "Force delete? [y/N] " force_del
                if [[ "$force_del" =~ ^[Yy]$ ]]; then
                    git --git-dir="$git_dir" branch -D "$branch" >&2
                fi
            fi
        fi
    fi

    echo "Task completed: ${selected}" >&2
}

cmd_open() {
    local dir
    dir="$WORKTREE_DIR"

    if [ ! -d "$dir" ]; then
        echo "Worktree directory not found: $dir" >&2
        exit 1
    fi

    local selected
    selected=$(cmd_ls | fzf --prompt="Select Task> ")

    if [ -z "$selected" ]; then
        echo "Cancelled." >&2
        exit 1
    fi

    local workdir="${dir}/${selected}"
    local repo_name="${selected%%__*}"
    local branch="${selected#*__}"

    open_editor "$repo_name" "$workdir" "$branch" "true"
}

cmd_new() {
    cd "$WORKSPACE_DIR"

    selected_repo=$(select_repo)
    cd "$selected_repo"

    repo_name=$(basename "$(pwd)")

    branch_info=$(select_branch)
    branch=$(echo "$branch_info" | head -n 1)
    branch_type=$(echo "$branch_info" | tail -n 1)

    git_args=()
    target_branch="$branch"

    if [ "$branch_type" = "existing" ]; then
        action=$(ask_branch_action)
        if [ "$action" = "new_from_base" ]; then
            new_name=$(input_new_branch_name)
            target_branch="$new_name"
            # Fetch latest if remote branch exists
            if git ls-remote --exit-code origin "$branch" >/dev/null 2>&1; then
                echo "Fetching latest '${branch}'..." >&2
                git fetch origin "$branch" >&2
                git_args=(-b "$target_branch" "origin/$branch")
            else
                git_args=(-b "$target_branch" "$branch")
            fi
        else
            git_args=("$branch")
        fi
    else
        git_args=(-b "$branch")
    fi

    result=$(create_worktree ${WORKTREE_DIR}/"${repo_name}__${target_branch}" "${git_args[@]}")
    worktree_status="${result%%:*}"
    workdir="${result#*:}"

    link_ignored_files "$(pwd)" "$workdir"

    local resume="false"
    if [ "$worktree_status" = "existing" ]; then
        resume="true"
    fi

    open_editor "$repo_name" "$workdir" "$target_branch" "$resume"
}

main() {
    local cmd="${1:-}"
    case "$cmd" in
        new)
            shift
            cmd_new "$@"
            ;;
        ls)
            shift
            cmd_ls "$@"
            ;;
        open)
            shift
            cmd_open "$@"
            ;;
        status)
            shift
            cmd_status "$@"
            ;;
        done)
            shift
            cmd_done "$@"
            ;;
        *)
            usage
            ;;
    esac
}

main "$@"
